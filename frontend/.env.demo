# Loaded with: npm run dev:demo
# Sample calendar/tasks/lists; no HA WebSocket. Weather still uses Open-Meteo from the browser.
VITE_SKYDARK_DEMO=true
# Optional: force ambient weather card (rain/snow/sun/cloud). Restart dev after changing.
# Or use URL: #/calendar?demoWeather=rain  (same values: sunny partly-cloudy cloudy rain snow)
# VITE_SKYDARK_DEMO_WEATHER=rain
