# Copy to `.env.local` (gitignored) for local dev against a real Home Assistant — no OAuth loop,
# no HACS pull, no HA restart. Restart `npm run dev` after editing.

# Required: MUST match exactly how you open Home Assistant in the browser (scheme + host + port).
#
# Troubleshooting "WebSocket connection to wss://… failed":
# - Windows often resolves *.local unreliably for WebSockets — use your HA LAN IP instead, e.g.
#     VITE_HASS_URL=http://192.168.1.50:8123
# - Use http:// if HA uses plain HTTP at home; use https:// only if HA serves HTTPS (same as browser).
# - Self-signed HTTPS: open that URL in a normal browser tab once and accept the certificate first.
# - If you use Cloudflare/nginx in front of HA for remote access, dev machine should still use the
#   direct LAN URL above — not the public hostname — unless WebSockets are explicitly allowed there.
VITE_HASS_URL=http://192.168.1.10:8123

# Optional but recommended for friction-free dev:
# HA → Profile (bottom left) → Security → Long-lived access tokens → Create token.
# Paste the token below. Without it, `npm run dev` falls back to OAuth once per browser profile.
VITE_HASS_ACCESS_TOKEN=
