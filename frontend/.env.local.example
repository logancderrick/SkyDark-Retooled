# Copy to `.env.local` (gitignored) for local dev against a real Home Assistant — no OAuth loop,
# no HACS pull, no HA restart. Restart `npm run dev` after editing.

# Required: your HA base URL (same origin you use in the browser).
VITE_HASS_URL=https://homeassistant.local:8123

# Optional but recommended for friction-free dev:
# HA → Profile (bottom left) → Security → Long-lived access tokens → Create token.
# Paste the token below. Without it, `npm run dev` falls back to OAuth once per browser profile.
VITE_HASS_ACCESS_TOKEN=
